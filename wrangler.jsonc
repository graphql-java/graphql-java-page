{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "graphql-java-page",
  "compatibility_date": "2026-05-06",
  "assets": {
    "directory": "./build",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "graphql-java.com",
      "custom_domain": true
    },
    {
      "pattern": "www.graphql-java.com",
      "custom_domain": true
    }
  ]
}
